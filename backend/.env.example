# =============================================================
# WhatsApp Bot MVP - Environment Variables
# Copy this file to .env and fill in your real values
# =============================================================

# --- Neon Postgres ---
# Get this from your Neon dashboard: https://neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_S0lbC3mTqLKa@ep-curly-tree-aip6ue0b-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# --- OpenAI ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Server ---
PORT=3001

# --- Business Info (used in PDF invoices) ---
BUSINESS_NAME=My Business
BUSINESS_ADDRESS=123 Main Street, City, Country
BUSINESS_PHONE=+1234567890
BUSINESS_EMAIL=hello@mybusiness.com

# --- Invoice Storage ---
# Directory where generated PDF invoices are saved locally
INVOICE_DIR=./invoices

# --- WhatsApp Session ---
# Directory to persist the Baileys auth session (so you don't re-scan QR every restart)
SESSION_DIR=./sessions

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:5173

# --- Payment Link (optional, shown in invoice or WhatsApp message) ---
# Add your Stripe / PayPal / bank link here
PAYMENT_LINK=https://pay.yourplatform.com/your-link
